<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_soft_gradient"
    tools:context=".TambahKeahlianActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Tambah Keahlian"
            android:textColor="@color/dark_olive"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_cancel_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Batal"
            android:textColor="#888888"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Search bar -->
    <EditText
        android:id="@+id/et_search"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_input_new"
        android:hint="Cari bidang keahlian..."
        android:textColorHint="#888888"
        android:textColor="#1A1A1A"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        android:singleLine="true"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- List of skills -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/et_search"
        app:layout_constraintBottom_toTopOf="@id/btn_simpan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layout_skills_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Skill items will be listed here, we will define some pre-populated static views too for simplicity or let code inflate them. Let's write them statically first to ensure beautiful previews. -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_gray"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Cloud Computing"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_gray"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Cybersecurity"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_gray"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Data Analysis"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_gray"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Database Management"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_gray"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Mobile Development"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_gray"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Networking"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_gray"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Programming"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_gray"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="UI/UX Design"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_gray"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Web Development"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Bottom: Simpan -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_simpan"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_btn_primary"
        android:text="💾 Simpan Pengalaman"
        android:textAllCaps="false"
        android:textColor="#1A1A1A"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
