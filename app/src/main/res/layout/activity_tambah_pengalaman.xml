<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_soft_gradient"
    tools:context=".TambahPengalamanActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Edit Pengalaman"
            android:textColor="@color/dark_olive"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_cancel_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Batal"
            android:textColor="#888888"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- Field 1: Organisasi / Perusahaan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Organisasi / Perusahaan"
                android:textColor="@color/dark_olive"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_organisasi"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_new"
                android:hint="Masukkan nama organisasi"
                android:textColorHint="#888888"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:singleLine="true" />

            <!-- Field 2: Jabatan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Jabatan"
                android:textColor="@color/dark_olive"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_jabatan"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_new"
                android:hint="Masukkan jabatan"
                android:textColorHint="#888888"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:singleLine="true" />

            <!-- Field: Lokasi / Posisi (added to match db model) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Lokasi / Posisi"
                android:textColor="@color/dark_olive"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_posisi"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_new"
                android:hint="Masukkan lokasi (cth: Surabaya)"
                android:textColorHint="#888888"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:singleLine="true" />

            <!-- Dates Side by Side -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tanggal mulai"
                        android:textColor="@color/dark_olive"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_tanggal_mulai"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_new"
                        android:hint="Pilih tanggal"
                        android:textColorHint="#888888"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:paddingHorizontal="14dp"
                        android:drawableEnd="@drawable/ic_calendar"
                        android:drawableTint="#888888"
                        android:focusable="false"
                        android:clickable="true" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selesai"
                        android:textColor="@color/dark_olive"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_tanggal_selesai"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_new"
                        android:hint="Pilih tanggal"
                        android:textColorHint="#888888"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:paddingHorizontal="14dp"
                        android:drawableEnd="@drawable/ic_calendar"
                        android:drawableTint="#888888"
                        android:focusable="false"
                        android:clickable="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- Checkbox: Saat ini bekerja di sini -->
            <CheckBox
                android:id="@+id/cb_masih_bekerja"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Saat ini bekerja di sini"
                android:textColor="#1A1A1A"
                android:textSize="13sp" />

            <!-- Field 5: Deskripsi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Deskripsi"
                android:textColor="@color/dark_olive"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_deskripsi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_new"
                android:hint="Masukkan deskripsi pekerjaan..."
                android:textColorHint="#888888"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:padding="14dp"
                android:minLines="4"
                android:gravity="top" />

            <!-- Field 6: Keahlian yang Digunakan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Keahlian yang Digunakan"
                android:textColor="@color/dark_olive"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Horizontal container for skills and button -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layout_skills_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/btn_tambah_keahlian"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tag_pill"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="＋ Tambah Keahlian"
                        android:textColor="#1A1A1A"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Actions: Save & Delete -->
    <LinearLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_simpan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_primary"
            android:text="💾 Simpan Pengalaman"
            android:textAllCaps="false"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_delete_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="Hapus Pengalaman"
            android:textColor="#E53935"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
