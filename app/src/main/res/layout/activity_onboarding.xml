<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_soft_gradient"
    tools:context=".OnboardingActivity">

    <!-- Card Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/onboarding_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/bg_light_blue_gray"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="32dp"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/iv_onboarding_icon"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_folder_star"
                android:layout_marginTop="16dp"
                android:contentDescription="Onboarding Step Icon" />

            <TextView
                android:id="@+id/tv_onboarding_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Kelola Pengalaman"
                android:textColor="@color/dark_olive"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_onboarding_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Dokumentasikan riwayat pengalaman organisasi, kepanitiaan, atau pekerjaan Anda secara terstruktur."
                android:textColor="#888888"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingExtra="3sp" />

            <!-- Progress Indicator Dots -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="36dp"
                android:gravity="center">

                <View
                    android:id="@+id/dot1"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dark_pill"
                    android:backgroundTint="@color/primary_yellow"
                    android:layout_marginHorizontal="4dp" />

                <View
                    android:id="@+id/dot2"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dark_pill"
                    android:backgroundTint="#DDE3EC"
                    android:layout_marginHorizontal="4dp" />

                <View
                    android:id="@+id/dot3"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dark_pill"
                    android:backgroundTint="#DDE3EC"
                    android:layout_marginHorizontal="4dp" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_next"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_btn_primary"
                android:text="Lanjutkan →"
                android:textAllCaps="false"
                android:textColor="@color/button_secondary_stroke"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom Small Icons Deco -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:gravity="center">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_folder_star"
            android:layout_marginHorizontal="8dp"
            app:tint="@color/dark_olive"
            android:alpha="0.5" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_shield"
            android:layout_marginHorizontal="8dp"
            app:tint="@color/dark_olive"
            android:alpha="0.5" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chart"
            android:layout_marginHorizontal="8dp"
            app:tint="@color/dark_olive"
            android:alpha="0.5" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
